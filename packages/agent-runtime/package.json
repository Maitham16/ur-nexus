{
  "name": "@ur/agent-runtime",
  "version": "1.0.3",
  "description": "UR-Nexus shared agent runtime for CLI and Desktop",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=18.18",
    "bun": ">=1.3.0"
  },
  "license": "LicenseRef-UR-Nexus-Non-Commercial-Self-Responsibility",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm --splitting",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "diff2html": "^3.4.56",
    "sharp": "^0.35.1"
  }
}
