{
  "name": "@ur/desktop",
  "version": "1.44.7",
  "description": "UR-Nexus desktop app",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run build:main && bun run build:preload && concurrently \"bun run dev:vite\" \"bun run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron ./dist/main/main.mjs",
    "build": "bun run build:main && bun run build:preload && bun run build:vite",
    "build:main": "esbuild src/main/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/main/main.mjs --external:electron --external:node-pty --external:electron-updater --sourcemap",
    "build:preload": "esbuild src/preload/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/preload/preload.mjs --external:electron --sourcemap",
    "build:vite": "vite build",
    "build:electron": "electron-builder",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@ur/agent-runtime": "workspace:*",
    "electron-updater": "^6.8.9",
    "node-pty": "^1.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.24.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.7.0",
    "vite": "^5.3.0",
    "wait-on": "^7.2.0"
  }
}
