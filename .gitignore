# Dependencies
node_modules/
.bun/
# Project uses bun (bun.lock); ignore stray npm lock from accidental `npm i`
package-lock.json

# Build and generated output
backup/
dist/*
!dist/cli.js
build/
coverage/
.nyc_output/
*.tsbuildinfo

# Test and browser artifacts
test-results/
playwright-report/

# Logs and runtime files
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-debug.log*
*.pid
*.seed

# Environment files and local secrets
.env
.env.*
!.env.example
*.pem
*.p12
*.pfx
*.crt
*.csr
*.keystore
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
credentials.json
service-account*.json
secrets.json
tokens.json
oauth-token.json

# Stray lockfiles from other package managers (bun.lock is canonical)
yarn.lock

# FUSE filesystem artifacts (files held open during deletion)
.fuse_hidden*

# UR local state that should stay machine-specific
UR.local.md
.ur/context/
.ur/plans/
.ur/settings.local.json
.ur/*.local.json
.ur/index/
.ur/memory/
.ur/semantic-memory/index/
.ur/brainstorming/
.ur/agent-memory-local/
.ur/scheduled_tasks.json
.ur/actions.jsonl
.ur/cache/
.ur/tmp/
.ur/logs/
.ur/background/
.ur/worktrees/
.ur/ide/
.ur/runs/
.ur-analysis/

# Release build artifacts (regenerated; avoid nested archives in publish)
artifacts/source/*.zip

# OS and editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# Package manager caches
.npm/
.pnpm-store/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz
